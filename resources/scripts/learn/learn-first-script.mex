#include <max.mh>

int main()
{
  print("\n|11Hello, |15", usr.name, "|11.\n\n");
  print("|03You've called |14", usr.times, "|03 time");

  if (usr.times <> 1)
    print("s");

  print(".|07\n\n");

  return 0;
}
